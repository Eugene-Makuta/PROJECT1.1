# Frontend - Serve static HTML files with Nginx
FROM nginx:alpine

# Copy nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy frontend files
COPY *.html /usr/share/nginx/html/
COPY js/ /usr/share/nginx/html/js/
COPY *.js /usr/share/nginx/html/

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
